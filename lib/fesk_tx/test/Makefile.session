# Makefile for fesk_tx session tests (with base32 encoding)

CC = gcc
CFLAGS = -Wall -Wextra -std=c11 -I. -I.. -I../../base32
LDFLAGS =

# Directories
FESK_DIR = ..
BASE32_DIR = ../../base32
TEST_DIR = .

# Source files
FESK_TX_SRC = $(FESK_DIR)/fesk_tx.c
FESK_SESSION_SRC = $(FESK_DIR)/fesk_session.c
BASE32_SRC = $(BASE32_DIR)/base32.c
UNITY_SRC = unity.c
TEST_SRC = test_session.c

# Object files
FESK_TX_OBJ = fesk_tx_session.o
FESK_SESSION_OBJ = fesk_session.o
BASE32_OBJ = base32.o
UNITY_OBJ = unity_session.o
TEST_OBJ = test_session.o

# Output binary
TEST_BIN = test_fesk_session

.PHONY: all clean test run

all: $(TEST_BIN)

$(TEST_BIN): $(FESK_TX_OBJ) $(FESK_SESSION_OBJ) $(BASE32_OBJ) $(UNITY_OBJ) $(TEST_OBJ)
	$(CC) $(LDFLAGS) -o $@ $^

$(FESK_TX_OBJ): $(FESK_TX_SRC)
	$(CC) $(CFLAGS) -c -o $@ $<

$(FESK_SESSION_OBJ): $(FESK_SESSION_SRC)
	$(CC) $(CFLAGS) -c -o $@ $<

$(BASE32_OBJ): $(BASE32_SRC)
	$(CC) $(CFLAGS) -c -o $@ $<

$(UNITY_OBJ): $(UNITY_SRC)
	$(CC) $(CFLAGS) -c -o $@ $<

$(TEST_OBJ): $(TEST_SRC)
	$(CC) $(CFLAGS) -c -o $@ $<

test: $(TEST_BIN)
	./$(TEST_BIN)

run: test

clean:
	rm -f $(FESK_TX_OBJ) $(FESK_SESSION_OBJ) $(BASE32_OBJ) $(UNITY_OBJ) $(TEST_OBJ) $(TEST_BIN)
